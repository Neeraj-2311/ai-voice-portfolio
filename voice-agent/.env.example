# LiveKit: transport only (rooms / RPC between browser and worker), not the model gateway.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Voice pipeline (own keys, off LiveKit's metered gateway):
#   Deepgram nova-3 STT  ->  OpenAI gpt-5.3 LLM  ->  pluggable TTS (OpenAI by default).
OPENAI_API_KEY=      # REQUIRED: the LLM (brain) + the OpenAI TTS.
DEEPGRAM_API_KEY=    # REQUIRED: speech-to-text.

# TTS backend: openai (default) | kokoro | cartesia | cerebrium.
# kokoro = open-weight Kokoro-82M, runs in-process on CPU (~free, no key, ~0.5s).
TTS_BACKEND=openai
KOKORO_VOICE=bm_george    # used when TTS_BACKEND=kokoro; bm_lewis/am_fenrir, af_heart (female)

# Idle timeout: end the call when the visitor goes quiet. After IDLE_WARN_AFTER s
# of silence the agent nudges once, then hangs up IDLE_END_AFTER s later. 0 = off.
IDLE_WARN_AFTER=30
IDLE_END_AFTER=20

# Cartesia (TTS_BACKEND=cartesia): hosted streaming + voice cloning (~90ms).
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=   # your cloned voice id; blank = stock Cartesia voice
# CARTESIA_MODEL=sonic-2   # optional; defaults to sonic-2

# Cal.com v2 API key for real booking over voice (cal.com -> Settings -> Developer -> API keys).
# Event-type IDs are the numeric ids for the cal.com/<username>/hire and /mentor event types.
CAL_API_KEY=
CAL_EVENT_TYPE_HIRE=
CAL_EVENT_TYPE_MENTOR=
CAL_TIMEZONE=Asia/Kolkata

# Resend: the agent sends lead / callback / contact emails directly (low latency, no Next.js hop).
RESEND_API_KEY=
RESEND_FROM=
RESEND_TO=

# Google Sheets fallback (used only when the Resend email send fails).
# Service account JSON: email + private key (with literal \n newlines), and the target sheet id.
# Leave unset to disable the fallback (the agent logs the lead instead).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEETS_LEADS_ID=

# Cerebrium streaming voice-clone TTS (optional). CEREBRIUM_TTS=1 routes speech
# through the deployed `voice-clone-tts` app instead of OpenAI TTS; 0/unset uses OpenAI.
CEREBRIUM_TTS=0
CEREBRIUM_TTS_WS_URL=    # wss://api.<region>.cerebrium.ai/v4/<project-id>/voice-clone-tts/v1/tts/stream
CEREBRIUM_JWT=           # project JWT from the Cerebrium dashboard (API keys)
CEREBRIUM_SPEAKER_URL=   # public ~10s wav/mp3 of the voice to clone; unset = default voice
