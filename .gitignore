# Root-level ignores. Each app also has its own .gitignore:
#   web/.gitignore           (Next.js)
#   voice-agent/.gitignore   (Python / uv)

# OS
.DS_Store

# Safety net: never commit real env files or local secrets anywhere in the tree.
# Only *.example files are allowed through.
**/.env
**/.env.*
!**/.env.example
**/.mcp.json
