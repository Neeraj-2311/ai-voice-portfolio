# Public site URL. Used for metadataBase, OG image URLs, sitemap, canonical tags.
# Do NOT include a trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public inbound email. Surfaced in the footer, contact modal, hire CTAs,
# privacy page, and the mailto links throughout the site.
NEXT_PUBLIC_SITE_EMAIL=hello@example.com

# Plausible analytics — leave unset to disable the script entirely.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=neeraj.dev

# Cal.com username. Event slugs are fixed: `hire` and `mentor`.
# Booking links resolve to cal.com/<username>/hire and cal.com/<username>/mentor.
NEXT_PUBLIC_CAL_USERNAME=hineeraj
# CAL_API_KEY is only needed for Phase 2 (programmatic booking over voice).
# CAL_API_KEY=

# LiveKit (Phase 2 voice agent). Server keys mint short-lived tokens for the
# browser to join a room. NEXT_PUBLIC_LIVEKIT_URL is the wss endpoint the
# client connects to.
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
# NEXT_PUBLIC_LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud

# Resend used by the contact form server action to email Neeraj.
# Generate at https://resend.com/api-keys; sender domain must be verified.
# RESEND_API_KEY=
# RESEND_FROM=noreply@neeraj.dev
# RESEND_TO defaults to NEXT_PUBLIC_SITE_EMAIL when unset.
# RESEND_TO=hello@example.com
